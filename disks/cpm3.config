# image config file for cpm3 disc
imagefilename=disks/cpm3.img
cyls = 80
heads = 2
secs = 10
bps = 512
id=0
mode=mfm
iam = no
#   interleaved:   Interleaved cylinder ordering: c0s0, c0s1, c1s0, c1s1, . . .
#   sequntial:   side 1 follows side 0 : c0c0 c1s0 c2s0 . . . c79s0 c0 s1 c1 s1 . . . 
file-layout = interleaved
write-protect=n


